# ============================================================
# CopyForge — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- DeepSeek (AI Provider) ---
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# Optional: specify model (default: deepseek-v4-flash)
DEEPSEEK_MODEL=deepseek-v4-flash

# --- Neon PostgreSQL ---
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- NextAuth (choose at least one auth provider) ---

# Option A: Auth0 (recommended)
# https://manage.auth0.com -> Applications -> Create Regular Web App
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_ISSUER=https://your-tenant.us.auth0.com

# Option B: GitHub OAuth
# https://github.com/settings/developers -> New OAuth App
AUTH_GITHUB_ID=your-github-oauth-id
AUTH_GITHUB_SECRET=your-github-oauth-secret

# Required by NextAuth
AUTH_SECRET=generate-a-random-secret-here

# --- Creem (Payment) ---
# Get your API key from: https://dashboard.creem.io
CREEM_API_KEY=creem-api-key-here
# Product IDs for each paid tier
CREEM_PRODUCT_ID_CREATOR=creem-product-id-for-creator
CREEM_PRODUCT_ID_PRO=creem-product-id-for-pro
CREEM_WEBHOOK_SECRET=creem-webhook-secret-here

# --- App ---
# Used for Creem success/cancel redirects
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Optional: Resend (Email auth magic link) ---
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=noreply@lxs.best
