// ============================================================
// Prisma Schema — AI Copy Generator
// Database: Neon PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 用户表：存储用户信息及剩余生成次数
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  image     String?
  freeCount Int       @default(2)    // 免费生成次数（默认 2 次）
  paidCount Int       @default(0)    // 已购买的付费生成次数
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// 文章表：存储每次 AI 生成的结果
model Article {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String                    // 用户输入的关键词/主题
  content   String                    // AI 生成的文案内容
  template  String   @default("blog") // 模板风格：blog | news | ecommerce | academic
  createdAt DateTime @default(now())

  @@index([userId])
}
